rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if requester is admin
    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users collection
    match /users/{userId} {
      // Any logged-in user can read their own profile; admins can read all
      allow read: if request.auth != null &&
        (request.auth.uid == userId || isAdmin());

      // Only the user themselves can create their profile
      allow create: if request.auth != null && request.auth.uid == userId;

      // User can update their own profile; admins can update any
      allow update: if request.auth != null &&
        (request.auth.uid == userId || isAdmin());

      // Only admins can delete users
      allow delete: if isAdmin();
    }

    // Gigs collection
    match /gigs/{gigId} {
      // Any logged-in user can read gigs
      allow read: if request.auth != null;

      // Any logged-in user can post a gig
      allow create: if request.auth != null &&
        request.resource.data.postedBy == request.auth.uid;

      // Owner or admin can update (includes applying — arrayUnion on applicants)
      allow update: if request.auth != null &&
        (resource.data.postedBy == request.auth.uid || isAdmin());

      // Only admins can delete gigs
      allow delete: if isAdmin();
    }

    // Products collection
    match /products/{productId} {
      // Any logged-in user can read products
      allow read: if request.auth != null;

      // Any logged-in user can list a product
      allow create: if request.auth != null &&
        request.resource.data.sellerId == request.auth.uid;

      // Seller or admin can update
      allow update: if request.auth != null &&
        (resource.data.sellerId == request.auth.uid || isAdmin());

      // Seller or admin can delete
      allow delete: if request.auth != null &&
        (resource.data.sellerId == request.auth.uid || isAdmin());
    }
  }
}
